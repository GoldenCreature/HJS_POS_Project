<Window x:Class="HJS_POS_Project.Views.SalesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HJS_POS_Project.ViewModels"
        Title="판매 처리" Height="750" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:SalesViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽 상품 검색 및 목록 -->
        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- 검색 바 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Height="35" FontSize="13"
                         Padding="8,0" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="검색" Height="35"
                        Background="#1E2761" Foreground="White"
                        Command="{Binding SearchCommand}"/>
            </Grid>

            <!-- 상품 목록 -->
            <DataGrid Grid.Row="1" Margin="0,10,0,0"
                      ItemsSource="{Binding ProductList}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="상품명" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="100"/>
                    <DataGridTextColumn Header="단가" Binding="{Binding Price, StringFormat={}{0:N0}원}" Width="100"/>
                    <DataGridTextColumn Header="재고" Binding="{Binding Stock}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 선택 상품 이미지 미리보기 -->
            <Border Grid.Row="2" Margin="0,10,0,0"
                    BorderBrush="#DDDDDD" BorderThickness="1"
                    Background="#F5F5F5">
                <Image Source="{Binding PreviewImage}"
                       Stretch="Uniform" Margin="5"/>
            </Border>
        </Grid>

        <!-- 오른쪽 장바구니 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="55"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <!-- 장바구니 타이틀 -->
            <Rectangle Grid.Row="0" Fill="#1E2761"/>
            <TextBlock Grid.Row="0" Text="🛒 장바구니"
                       FontSize="15" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- 장바구니 목록 -->
            <DataGrid Grid.Row="1" Margin="0,5"
                      ItemsSource="{Binding CartList}"
                      SelectedItem="{Binding SelectedCartItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="상품명" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="수량" Binding="{Binding Stock}" Width="50"/>
                    <DataGridTextColumn Header="금액" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 수량 입력 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="수량" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Height="33" FontSize="13"
                         Padding="8,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Content="담기" Height="33"
                        Margin="8,0,0,0" Padding="12,0"
                        Background="#2C5F2D" Foreground="White"
                        Command="{Binding AddToCartCommand}"/>
            </Grid>

            <!-- 결제 수단 선택 -->
            <Grid Grid.Row="3" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="결제수단" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="rbCash" Grid.Column="1" Content="현금" FontSize="13"
                             GroupName="PaymentType" IsChecked="True"
                             Checked="PaymentType_Checked"
                             VerticalAlignment="Center"/>
                <RadioButton x:Name="rbCard" Grid.Column="2" Content="카드" FontSize="13"
                             GroupName="PaymentType"
                             Checked="PaymentType_Checked"
                             VerticalAlignment="Center"/>
            </Grid>

            <!-- 합계 -->
            <Border Grid.Row="4" Background="#F0F0F0" Margin="0,5">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="합계"
                               FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalAmount, StringFormat={}{0:N0}원}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#1E2761"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 결제 및 취소 버튼 -->
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="결제" Margin="0,0,4,0"
                        Background="#1E2761" Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        Command="{Binding PayCommand}"/>
                <Button Grid.Column="1" Content="취소" Margin="4,0,0,0"
                        Background="#8B0000" Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        Command="{Binding CancelCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>