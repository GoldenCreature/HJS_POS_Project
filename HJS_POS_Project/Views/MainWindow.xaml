<Window x:Class="HJS_POS_Project.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HJS_POS_Project.ViewModels"
        Title="POS 메인" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 상단 타이틀 -->
        <Rectangle Grid.Row="0" Fill="#1E2761"/>
        <TextBlock Grid.Row="0" Text="POS 관리 시스템"
                   FontSize="24" FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- 메뉴 버튼 3개 -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="40">

            <!-- 상품 관리 -->
            <Button Margin="10"
                    Command="{Binding ProductCommand}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📦" FontSize="40"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="상품 관리" FontSize="16"
                               FontWeight="Bold" Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="상품 등록 · 수정 · 삭제"
                               FontSize="11" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 판매 처리 -->
            <Button Margin="10"
                    Command="{Binding SalesCommand}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🛒" FontSize="40"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="판매 처리" FontSize="16"
                               FontWeight="Bold" Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="장바구니 · 결제 처리"
                               FontSize="11" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 매출 통계 -->
            <Button Margin="10"
                    Command="{Binding StatisticsCommand}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📊" FontSize="40"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="매출 통계" FontSize="16"
                               FontWeight="Bold" Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="일별 · 월별 매출 차트"
                               FontSize="11" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

        </UniformGrid>

        <!-- 하단 상태바 -->
        <Rectangle Grid.Row="2" Fill="#F0F0F0"/>
        <TextBlock Grid.Row="2" Text="HJS POS System v1.0"
                   FontSize="11" Foreground="Gray"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,15,0"/>
    </Grid>
</Window>