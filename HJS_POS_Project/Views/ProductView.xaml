<Window x:Class="HJS_POS_Project.Views.ProductView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HJS_POS_Project.ViewModels"
        Title="상품 관리" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:ProductViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽 상품 목록 -->
        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 검색 바 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Height="35" FontSize="13"
                         Padding="8,0" Margin="0,0,8,0"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                         Tag="상품명 검색"/>
                <Button Grid.Column="1" Content="검색" Height="35"
                        Background="#1E2761" Foreground="White"
                        Command="{Binding SearchCommand}"/>
            </Grid>

            <!-- 상품 목록 DataGrid -->
            <DataGrid Grid.Row="1" Margin="0,10,0,0"
                      ItemsSource="{Binding ProductList}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ProductID}" Width="50"/>
                    <DataGridTextColumn Header="상품명" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="100"/>
                    <DataGridTextColumn Header="단가" Binding="{Binding Price, StringFormat={}{0:N0}원}" Width="100"/>
                    <DataGridTextColumn Header="재고" Binding="{Binding Stock}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- 오른쪽 입력 폼 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 폼 타이틀 -->
            <Rectangle Grid.Row="0" Fill="#1E2761" Height="45"/>
            <TextBlock Grid.Row="0" Text="상품 정보 입력"
                       FontSize="15" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- 입력 필드 -->
            <StackPanel Grid.Row="1" Margin="10,15">

                <TextBlock Text="상품명" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Height="33" FontSize="13" Padding="8,0" Margin="0,0,0,12"
                         Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="카테고리" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Height="33" FontSize="13" Padding="8,0" Margin="0,0,0,12"
                         Text="{Binding InputCategory, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="단가" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Height="33" FontSize="13" Padding="8,0" Margin="0,0,0,12"
                         Text="{Binding InputPrice, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="재고 수량" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Height="33" FontSize="13" Padding="8,0" Margin="0,0,0,12"
                         Text="{Binding InputStock, UpdateSourceTrigger=PropertyChanged}"/>

            </StackPanel>

            <!-- 버튼 영역 -->
            <StackPanel Grid.Row="2" Margin="10,0,10,10">
                <Button Content="추가" Height="38" Margin="0,0,0,8"
                        Background="#2C5F2D" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        Command="{Binding AddCommand}"/>
                <Button Content="수정" Height="38" Margin="0,0,0,8"
                        Background="#185FA5" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        Command="{Binding UpdateCommand}"/>
                <Button Content="삭제" Height="38"
                        Background="#8B0000" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>