<Window x:Class="HJS_POS_Project.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HJS_POS_Project.ViewModels"
        Title="POS 로그인" Height="380" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <!-- DataContext에 LoginViewModel 연결 -->
    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 타이틀 -->
        <Rectangle Grid.Row="0" Fill="#1E2761"/>
        <TextBlock Grid.Row="0" Text="POS 시스템"
                   FontSize="24" FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- 로그인 폼 -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    Margin="50,20">

            <TextBlock Text="아이디" FontSize="13" Margin="0,0,0,5"/>
            <TextBox Height="38" FontSize="14" Padding="10,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="비밀번호" FontSize="13" Margin="0,18,0,5"/>
            <PasswordBox x:Name="txtPassword"
                         Height="38" FontSize="14" Padding="10,0"
                         VerticalContentAlignment="Center"/>

            <Button Content="로그인"
                    Height="42" Margin="0,25,0,0"
                    FontSize="15" FontWeight="Bold"
                    Background="#1E2761" Foreground="White"
                    Click="btnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>