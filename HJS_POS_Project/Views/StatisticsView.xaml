<Window x:Class="HJS_POS_Project.Views.StatisticsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HJS_POS_Project.ViewModels"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="매출 통계" Height="750" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:StatisticsViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 상단 날짜 선택 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="시작일" FontSize="13"
               VerticalAlignment="Center" Margin="0,0,8,0"/>
            <DatePicker Grid.Column="1" Height="33"
                        VerticalContentAlignment="Center"
                SelectedDate="{Binding StartDate}"/>
            <TextBlock Grid.Column="2" Text=" ~ " FontSize="13"
               VerticalAlignment="Center" Margin="8,0"/>
            <TextBlock Grid.Column="3" Text="종료일" FontSize="13"
               VerticalAlignment="Center" Margin="0,0,8,0"/>
            <DatePicker Grid.Column="4" Height="33"
                        VerticalContentAlignment="Center"
                SelectedDate="{Binding EndDate}"/>
            <Button Grid.Column="5" Content="조회" Height="33"
            Margin="8,0,0,0" Padding="15,0"
            Background="#1E2761" Foreground="White"
            Command="{Binding SearchCommand}"/>

            <!-- 일간/월간 전환 버튼 -->
            <Button Grid.Column="6" Content="일간" Height="33"
            Margin="15,0,4,0"
            Command="{Binding DailyModeCommand}"/>
            <Button Grid.Column="7" Content="월간" Height="33"
            Margin="0,0,0,0"
            Command="{Binding MonthlyModeCommand}"/>
        </Grid>

        <!-- 중간 차트 영역 -->
        <Border Grid.Row="1" Margin="0,10"
                BorderBrush="#DDDDDD" BorderThickness="1">
            <Grid>
                <TextBlock Text="조회 버튼을 눌러 매출 데이터를 불러오세요."
                           FontSize="14" Foreground="Gray"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsChartEmpty}"/>
                <!-- Chart 컨트롤 -->
                <oxy:PlotView Model="{Binding PlotModel}" Background="Transparent"/>
            </Grid>
        </Border>

        <!-- 하단 매출 목록 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 합계 표시 -->
            <Border Grid.Row="0" Background="#1E2761">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="총 매출"
                               FontSize="14" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalSales, StringFormat={}{0:N0}원}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 매출 목록 -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SalesList}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="주문번호" Binding="{Binding OrderID}" Width="80"/>
                    <DataGridTextColumn Header="주문일시" Binding="{Binding OrderDate}" Width="150"/>
                    <DataGridTextColumn Header="결제금액" Binding="{Binding TotalAmount, StringFormat={}{0:N0}원}" Width="120"/>
                    <DataGridTextColumn Header="결제수단" Binding="{Binding PaymentType}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>