<Window x:Class="HJS_POS_Project.Views.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="영수증" Height="500" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 매장명/타이틀 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="HJS POS" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="영 수 증" FontSize="13" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- 점선 구분선 -->
        <TextBlock Grid.Row="1" Text="--------------------------------------"
                   HorizontalAlignment="Center" Foreground="Gray" Margin="0,0,0,10"/>

        <!-- 구매 상품 목록 -->
        <ItemsControl Grid.Row="2" x:Name="icItems">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" FontSize="13"/>
                            <TextBlock Text="{Binding QtyText}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding PriceText}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 점선 구분선 -->
        <TextBlock Grid.Row="3" Text="--------------------------------------"
                   HorizontalAlignment="Center" Foreground="Gray" Margin="0,10,0,10"/>

        <!-- 합계 및 결제정보 -->
        <StackPanel Grid.Row="4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="합계" FontSize="15" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" x:Name="txtTotal" Text="0원"
                           FontSize="15" FontWeight="Bold"/>
            </Grid>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="결제수단" FontSize="12" Foreground="Gray"/>
                <TextBlock Grid.Column="1" x:Name="txtPaymentType" Text=""
                           FontSize="12" Foreground="Gray"/>
            </Grid>
            <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="결제일시" FontSize="12" Foreground="Gray"/>
                <TextBlock Grid.Column="1" x:Name="txtDate" Text=""
                           FontSize="12" Foreground="Gray"/>
            </Grid>

            <TextBlock Text="이용해 주셔서 감사합니다" FontSize="11"
                       Foreground="Gray" HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>